*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.pyo
*.pyd

# Virtual environments
venv/
env/
ENV/
.venv/
env.bak/
venv.bak/

# ----- Node.js -----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnp
.pnp.js

# Frontend build outputs
frontend/dist/
frontend/build/
frontend/dist-ssr/

# ----- Secrets & Environment Variables -----
.env
.env.*
!.env.example
backend/.env
.streamlit/secrets.toml

# YouTube cookies (contains session tokens — NEVER commit)
youtube-cookies.txt
backend/youtube-cookies.txt

# ----- AI Model Weights -----
*.pt
*.pth
*.bin
*.safetensors
*.onnx
*.gguf

# ----- FFmpeg Binaries -----
ffmpeg/

